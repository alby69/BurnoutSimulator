{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "text", "category", "choices"],
    "properties": {
      "id": { "type": "string" },
      "text": { "type": "string" },
      "category": { "type": "string" },
      "choices": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "text", "effects", "category"],
          "properties": {
            "id": { "type": "string" },
            "text": { "type": "string" },
            "category": { "type": "string", "enum": ["COMPLIANCE", "RESISTANCE", "NEGOTIATION", "ESCAPE"] },
            "effects": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            },
            "tags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "next_event_id": { "type": ["string", "null"] },
            "consequences": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["event_id", "after_turns"],
                "properties": {
                  "event_id": { "type": "string" },
                  "after_turns": { "type": "integer", "minimum": 1 },
                  "label": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
